# API Keys
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
HEYGEN_API_KEY=your_heygen_api_key_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id_here
INSTAGRAM_PAGE_URL=https://www.instagram.com/your_handle/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Server Configuration
PORT=3000
NODE_ENV=development
DATABASE_PATH=./database.sqlite

# Webhook Security
WEBHOOK_SECRET=your_secure_webhook_secret_here

# Optional: Logging
LOG_LEVEL=info

# Scheduler (UTC hours, comma-separated)
# Example below posts once per day: 08:00 UTC
DAILY_POST_TIMES_UTC=8

# Reel duration bounds in seconds (recommended for 1-2 min reels)
REEL_DURATION_MIN_SEC=60
REEL_DURATION_MAX_SEC=120

# TTS Configuration
TTS_PROVIDER=auto
COQUI_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
EDGE_TTS_VOICE=en-US-AvaMultilingualNeural
EDGE_TTS_RATE=+0%
AUTO_INSTALL_EDGE_TTS=1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Dashboard Access Control
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password
DASHBOARD_AUTH_SECRET=replace_with_long_random_secret
