<IfModule mod_authz_core.c>
  <FilesMatch "^(\.env|database\.sqlite|dashboard-config\.php|package\.json|package-lock\.json)$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(\.env|database\.sqlite|dashboard-config\.php|package\.json|package-lock\.json)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
